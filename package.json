{
  "name": "marketing-insights-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Auditable market intelligence bot for Neureos.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "run:report": "tsx src/scripts/run-report.ts"
  },
  "dependencies": {
    "cheerio": "latest",
    "dotenv": "latest",
    "drizzle-orm": "latest",
    "fast-xml-parser": "latest",
    "fastify": "latest",
    "pg": "latest",
    "pino": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/node": "latest",
    "drizzle-kit": "latest",
    "eslint": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vitest": "latest"
  }
}
